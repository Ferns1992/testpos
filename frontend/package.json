{
  "name": "quickmart-pos",
  "productName": "QuickMart POS",
  "version": "1.0.0",
  "description": "QuickMart POS - Modern Point of Sale System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:4070 && electron .\"",
    "install:backend": "cd ../backend && npm install",
    "prebuild": "npm run install:backend",
    "dist": "npm run build && electron-builder --win --dir",
    "dist:win": "npm run build && electron-builder --win --dir"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.8",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.quickmart.pos",
    "productName": "QuickMart POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    },
    "asar": false
  }
}
